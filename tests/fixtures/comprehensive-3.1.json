{
  "openapi": "3.1.0",
  "info": { "title": "Comprehensive Validation API", "version": "1.0.0" },
  "paths": {
    "/v1/products": {
      "get": {
        "operationId": "getProducts",
        "responses": {
          "200": {
            "description": "List of products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Product"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createProduct",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateProduct"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          }
        }
      }
    },
    "/v1/products/{productId}": {
      "get": {
        "operationId": "getProduct",
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "A single product",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Product"
                }
              }
            }
          }
        }
      }
    },
    "/v1/events": {
      "get": {
        "operationId": "getEvents",
        "responses": {
          "200": {
            "description": "List of events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 100,
                  "uniqueItems": true,
                  "items": {
                    "$ref": "#/components/schemas/Event"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/settings": {
      "get": {
        "operationId": "getSettings",
        "responses": {
          "200": {
            "description": "Application settings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Settings"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "required": ["id", "name", "price", "currency", "inStock", "category"],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "sku": {
            "type": "string",
            "pattern": "^[A-Z]{2,4}-\\d{4,8}$"
          },
          "description": {
            "type": ["string", "null"]
          },
          "price": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "compareAtPrice": {
            "type": ["number", "null"],
            "minimum": 0
          },
          "quantity": {
            "type": "integer",
            "minimum": 0,
            "maximum": 999999
          },
          "weight": {
            "type": "number",
            "multipleOf": 0.01
          },
          "rating": {
            "type": "number",
            "minimum": 0,
            "maximum": 5,
            "format": "float"
          },
          "inStock": {
            "type": "boolean"
          },
          "currency": {
            "type": "string",
            "enum": ["USD", "EUR", "GBP", "JPY"]
          },
          "category": {
            "type": "string",
            "enum": ["electronics", "clothing", "food", "books", "toys"]
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 0,
            "maxItems": 10,
            "uniqueItems": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "releaseDate": {
            "type": "string",
            "format": "date"
          },
          "website": {
            "type": "string",
            "format": "uri"
          },
          "contactEmail": {
            "type": "string",
            "format": "email"
          },
          "origin": {
            "type": "string",
            "format": "hostname"
          },
          "serverIp": {
            "type": "string",
            "format": "ipv4"
          },
          "serverIpV6": {
            "type": "string",
            "format": "ipv6"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "CreateProduct": {
        "type": "object",
        "required": ["name", "price", "currency", "category"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "price": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "currency": {
            "type": "string",
            "enum": ["USD", "EUR", "GBP", "JPY"]
          },
          "category": {
            "type": "string",
            "enum": ["electronics", "clothing", "food", "books", "toys"]
          }
        }
      },
      "Event": {
        "type": "object",
        "required": ["id", "name", "startDate", "active"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 100
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "active": {
            "type": "boolean"
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "format": "int32"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "exclusiveMaximum": 100,
            "format": "double"
          },
          "status": {
            "type": "string",
            "enum": ["draft", "published", "archived"]
          },
          "attendees": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "email"
            },
            "minItems": 1,
            "uniqueItems": true
          }
        }
      },
      "Settings": {
        "type": "object",
        "required": ["theme", "notifications", "language"],
        "additionalProperties": false,
        "properties": {
          "theme": {
            "type": "string",
            "enum": ["light", "dark", "auto"]
          },
          "notifications": {
            "type": "boolean"
          },
          "language": {
            "type": "string",
            "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
          },
          "customCss": {
            "type": ["string", "null"],
            "maxLength": 5000
          }
        }
      }
    }
  }
}
