{
  "openapi": "3.1.0",
  "info": { "title": "Events API", "version": "1.0.0" },
  "paths": {
    "/events": {
      "get": {
        "operationId": "getEvents",
        "responses": {
          "200": {
            "description": "List of events",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "minItems": 1,
                  "maxItems": 100,
                  "uniqueItems": true,
                  "items": {
                    "$ref": "#/components/schemas/Event"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/events/{eventId}": {
      "get": {
        "operationId": "getEvent",
        "parameters": [
          {
            "name": "eventId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "A single event",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Event"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Event": {
        "type": "object",
        "required": ["id", "name", "startDate", "active", "status"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 100
          },
          "startDate": {
            "type": "string",
            "format": "date-time"
          },
          "endDate": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "active": {
            "type": "boolean"
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5,
            "format": "int32"
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "exclusiveMaximum": 100,
            "format": "double"
          },
          "status": {
            "type": "string",
            "enum": ["draft", "published", "archived"]
          },
          "attendees": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "email"
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "description": {
            "type": ["string", "null"]
          },
          "capacity": {
            "type": ["integer", "null"],
            "minimum": 1
          }
        }
      }
    }
  }
}
